# Sauvegardes générées par backup.ps1 (données + storage sensibles, volumineux)
backup/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# TanStack Router — cache/artefacts de codegen
.tanstack/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Documentation interne (dépôt public) : doc projet.
# NB : la source de vérité du schéma est schema_complete.sql (versionné à la
# racine). Les migrations/ incrémentales NE sont PAS publiées — voir plus bas.
contexte/
# Plans de travail internes (corbeille, etc.) — comme contexte/, on ne publie pas la roadmap
plan/

# Données d'import legacy SQLite -> Supabase (dedale.db + documents réels, volumineux)
migration/
# Source SQLite legacy à la racine (données réelles à migrer ; dépôt PUBLIC -> jamais commité)
dedale.db
# Docs de migration legacy à la racine (gammes/OT/opérations) : données réelles -> jamais commités
migration-*.md

# Migrations SQL : dépôt PUBLIC → on ne les publie pas (elles peuvent contenir des
# données réelles, ex. coordonnées prestataires). Source de vérité du schéma =
# schema_complete.sql (versionné à la racine). Les fichiers existants sont
# dé-suivis (git rm --cached) ; ils restent en local pour être rejoués en prod.
migrations/

# Scripts de lancement locaux
dev.bat

# Réglages Claude Code personnels (le settings.json partagé reste versionné)
.claude/settings.local.json

# Supabase CLI — état local lié au projet
supabase/.temp/
