# Sauvegardes générées par backup.ps1 (données + storage sensibles, volumineux)
backup/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# TanStack Router — cache/artefacts de codegen
.tanstack/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Documentation interne (dépôt public) : doc projet + spec fonctionnelle legacy.
# NB : le schéma SQL (schema_complete.sql) et les migrations (migrations/) sont
# désormais versionnés à la racine — voir plus bas — pour suivre l'historique.
contexte/
doc-fonctionnelle/
# Plans de travail internes (corbeille, etc.) — comme contexte/, on ne publie pas la roadmap
plan/

# Données d'import legacy SQLite -> Supabase (dedale.db + documents réels, volumineux)
# Attention : « migration/ » (singulier, import legacy) est ignoré ; « migrations/ »
# (pluriel, historique SQL versionné à la racine) ne l'est PAS et doit rester suivi.
migration/

# Scripts de lancement locaux
dev.bat

# Réglages Claude Code personnels (le settings.json partagé reste versionné)
.claude/settings.local.json

# Supabase CLI — état local lié au projet
supabase/.temp/
